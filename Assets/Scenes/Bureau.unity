  m_text: "\u0421\u043F\u043E\u0441\u043E\u0431: \u0418\u0437\u0433\u043D\u0430\u043D\u0438\u0435
    \u0441\u0443\u0449\u043D\u043E\u0441\u0442\u0438 + \u043E\u0447\u0438\u0449\u0435\u043D\u0438\u0435
    \u0442\u0435\u043B\u0430\r\n\u0420\u0435\u0448\u0435\u043D\u0438\u0435: \u0418\u0437\u0433\u043D\u0430\u043D\u0438\u0435
    + \u043E\u0447\u0438\u0449\u0435\u043D\u0438\u0435\r\n\u041F\u0440\u0435\u0434\u043C\u0435\u0442\u044B:
