    \u041E\u0431\u0435\u0440\u0435\u0433 \u043F\u043E\u043A\u0430\u0437\u044B\u0432\u0430\u0435\u0442
    \u043D\u0430\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0435 \u043D\u0430
    \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A (\u043A\u0430\u043A \u043A\u043E\u043C\u043F\u0430\u0441),
