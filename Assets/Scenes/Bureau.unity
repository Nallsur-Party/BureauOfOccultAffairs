    \u041E\u0436\u0435\u0440\u0435\u043B\u044C\u0435 \u0440\u0430\u0437\u043E\u0440\u0432\u0430\u0442\u044C
    (\u0441\u0438\u043C\u0432\u043E\u043B\u0438\u0447\u0435\u0441\u043A\u0438 \u043F\u043E\u0440\u0432\u0430\u0442\u044C
    \u0446\u0435\u043F\u043E\u0447\u043A\u0443) \u2014 \u0438\u043B\u0438 \u043D\u0430\u043E\u0431\u043E\u0440\u043E\u0442,
    \u0437\u0430\u043A\u0440\u0435\u043F\u0438\u0442\u044C \u043D\u043E\u0432\u043E\u0439
    \u043A\u0440\u043E\u0432\u044C\u044E"
