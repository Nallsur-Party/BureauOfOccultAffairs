  m_text: "\u0420\u0435\u0448\u0435\u043D\u0438\u0435: \u0421\u043D\u044F\u0442\u044C
    \u0441\u0430\u043C\u043E\u043E\u0431\u043C\u0430\u043D\r\n\u041F\u0440\u0435\u0434\u043C\u0435\u0442\u044B:
    \u041E\u0431\u0435\u0440\u0435\u0433 + \u041F\u0430\u043B\u043E\u0447\u043A\u0430\r\n\u0414\u0435\u0439\u0441\u0442\u0432\u0438\u0435:
    \u041E\u0431\u0435\u0440\u0435\u0433 \u0434\u0430\u0442\u044C NPC (\u0437\u0430\u0449\u0438\u0442\u0430
    \u043D\u0430 \u0432\u0440\u0435\u043C\u044F \u043E\u0441\u043E\u0437\u043D\u0430\u043D\u0438\u044F),
    \u041F\u0430\u043B\u043E\u0447\u043A\u043E\u0439 \u043A\u043E\u0441\u043D\u0443\u0442\u044C\u0441\u044F
