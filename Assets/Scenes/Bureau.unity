  m_text: "\u0420\u0435\u0448\u0435\u043D\u0438\u0435: \u0421\u043E\u0437\u0434\u0430\u0442\u044C
    \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E\u0439 \u044F\u043A\u043E\u0440\u044C\r\n\u041F\u0440\u0435\u0434\u043C\u0435\u0442\u044B:
    \u041E\u0436\u0435\u0440\u0435\u043B\u044C\u0435 (\u0447\u0442\u043E-\u0442\u043E
    \u043B\u0438\u0447\u043D\u043E\u0435 NPC) + \u041F\u0430\u043B\u043E\u0447\u043A\u0430\r\n\u0414\u0435\u0439\u0441\u0442\u0432\u0438\u0435:
    \u041E\u0436\u0435\u0440\u0435\u043B\u044C\u0435 \u043D\u0430\u0434\u0435\u0442\u044C
    \u043D\u0430 NPC (\u043F\u0440\u0438\u0432\u044F\u0437\u0430\u0442\u044C \u043A
    \xAB\u0441\u0435\u0439\u0447\u0430\u0441\xBB), \u041F\u0430\u043B\u043E\u0447\u043A\u043E\u0439
    3 \u0440\u0430\u0437\u0430 \u0443\u0434\u0430\u0440\u0438\u0442\u044C \u043F\u043E
    \u0437\u0435\u043C\u043B\u0435 \u2014 \u0432\u0440\u0435\u043C\u044F \u0432\u044B\u0440\u0430\u0432\u043D\u0438\u0432\u0430\u0435\u0442\u0441\u044F"
