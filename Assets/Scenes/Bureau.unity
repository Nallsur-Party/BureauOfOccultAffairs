  m_text: "\u0420\u0435\u0448\u0435\u043D\u0438\u0435: \u041F\u0435\u0440\u0435\u043B\u043E\u0436\u0438\u0442\u044C
    \u0438\u043B\u0438 \u0440\u0430\u0437\u0440\u0443\u0448\u0438\u0442\u044C\r\n\u041F\u0440\u0435\u0434\u043C\u0435\u0442\u044B:
    \u041A\u0440\u0435\u0441\u0442 + \u041E\u0431\u0435\u0440\u0435\u0433\r\n\u0414\u0435\u0439\u0441\u0442\u0432\u0438\u0435:
    \u041E\u0431\u0435\u0440\u0435\u0433 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u044C
    \u043D\u0430 \u0433\u0440\u0443\u0434\u044C NPC (\u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E
    \u0437\u0430\u0449\u0438\u0442\u0438\u0442), \u041A\u0440\u0435\u0441\u0442\u043E\u043C
    \u043E\u0441\u0432\u044F\u0442\u0438\u0442\u044C \u043C\u0435\u0441\u0442\u043E
    \u2014 \u043F\u0440\u043E\u043A\u043B\u044F\u0442\u0438\u0435 \u0443\u0445\u043E\u0434\u0438\u0442"
  m_isRightToLeft: 0
